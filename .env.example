# Copy to .env and fill in. Never commit .env.

# --- Source APIs ---
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
USAJOBS_API_KEY=
# Adzuna/USAJobs require a contact email as the User-Agent:
USAJOBS_USER_AGENT=

# --- Anthropic (Claude API) ---
ANTHROPIC_API_KEY=

# --- Snowflake ---
# SNOWFLAKE_ACCOUNT is used by the Python code (dlt + dbt): format ORGNAME-ACCOUNTNAME.
SNOWFLAKE_ACCOUNT=
# The Terraform provider (v1) ignores SNOWFLAKE_ACCOUNT and needs the two halves split out.
# Find them in Snowsight -> Admin -> Accounts (Organization + Account columns), or split
# SNOWFLAKE_ACCOUNT on its hyphen: org = before, account = after.
SNOWFLAKE_ORGANIZATION_NAME=
SNOWFLAKE_ACCOUNT_NAME=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_ROLE=JOB_MARKET_ROLE
SNOWFLAKE_WAREHOUSE=JOB_MARKET_WH
SNOWFLAKE_DATABASE=JOB_MARKET
SNOWFLAKE_SCHEMA=RAW

# --- Redpanda (local default) ---
REDPANDA_BROKERS=localhost:19092
JOBS_TOPIC=raw_job_postings

# --- Serving store (cheap layer the public app reads) ---
SERVING_STORE_PATH=serving_store/active_jobs.parquet
